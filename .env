# PosgrSQL variables
PG_SSLMODE=

# MongoDB variables
MONGO_MIGRATIONS_METASTORE=database_migrations

# GeneralDB varibles
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=dc_test
INIT_DB_SCRIPT=init_pg.py
# INIT_DB_SCRIPT=init_mongo.py # if mongo
MIGRATIONS_DIR=migrations_broker_pg
#MIGRATIONS_DIR=migrations_broker_mongo # if mongo

# Master variables
MASTER_HOST=localhost
MASTER_PORT=8080
LOG_DIR=logs
MASTER_LOG_FILE=logs/master.log
MASTER_LOG_LEVEL=trace
HEARTBEAT_SEC=30
OFFLINE_SEC=120
MAX_LOG_UPLOAD_BYTES=10485760
MASTER_SKIP_DB_MIGRATION=false
