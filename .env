# PosgrSQL variables
PG_SSLMODE=

# MongoDB variables
MONGO_MIGRATIONS_METASTORE=database_migrations

# GeneralDB varibles
DB_BACKEND=mongo
DB_AUTHMODE=password
DB_HOST=broker
DB_NAME=dc_test
DB_PORT=27017
DB_USER=postgres
DB_PASSWORD=secret
DB_SSL_ROOTCERT=
DB_SSL_CERT=
DB_SSL_KEY=
# INIT_DB_SCRIPT=init_pg.py
INIT_DB_SCRIPT=init_mongo.py
# MIGRATIONS_DIR=migrations_broker_pg
MIGRATIONS_DIR=migrations_broker_mongo

# Master variables
# Used by host-side tools/CLI; docker-compose overrides master bind host to 0.0.0.0
MASTER_HOST=127.0.0.1
MASTER_PORT=8080
LOG_DIR=logs
MASTER_LOG_FILE=logs/master.log
MASTER_LOG_LEVEL=trace
HEARTBEAT_SEC=30
OFFLINE_SEC=120
BROKER_RECONNECT_ATTEMPTS=5
BROKER_RECONNECT_COOLDOWN_SEC=2
MAX_LOG_UPLOAD_BYTES=10485760
MASTER_SKIP_DB_MIGRATION=false

# Agent variables
AGENT_ID=worker-1
AGENT_OS=linux
AGENT_VERSION=dev
CPU_CORES=1
RAM_MB=0
SLOTS=1
WORKER_HTTP_TIMEOUT_MS=5000
WORKER_LOG_DIR=logs/worker
CANCEL_CHECK_SEC=1
UPLOAD_LOGS=true
MAX_UPLOAD_BYTES=10485760
WORKER_LOG_LEVEL=info
WORKER_LOG_FILE=logs/worker/worker.log
