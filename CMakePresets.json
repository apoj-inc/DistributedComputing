{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "full-native-release",
      "displayName": "Full Matrix Native Release",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/native",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "DC_BUILD_WIN_WORKER": "OFF"
      }
    },
    {
      "name": "x86_64-linux",
      "displayName": "Linux x86_64",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/x86_64-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/toolchains/x86_64-linux-gnu.cmake",
        "DC_ONLY_WORKER": "OFF",
        "DC_BUILD_MASTER": "ON",
        "DC_BUILD_CLI": "ON",
        "DC_BUILD_WIN_WORKER": "OFF"
      }
    },
    {
      "name": "arm-linux",
      "displayName": "Full Matrix ARM Release",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/arm-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/toolchains/arm64-linux-gnu.cmake",
        "DC_ONLY_WORKER": "OFF",
        "DC_BUILD_MASTER": "ON",
        "DC_BUILD_CLI": "ON",
        "DC_BUILD_WIN_WORKER": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "full-native-release",
      "configurePreset": "full-native-release"
    },
    {
      "name": "x86_64-linux",
      "configurePreset": "x86_64-linux"
    },
    {
      "name": "arm-linux",
      "configurePreset": "arm-linux"
    }
  ]
}
